# ========================
# ArogyaMitra — .gitignore
# ========================

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg
*.egg-info/
dist/
build/
.eggs/
.cache/

# Environment variables (NEVER commit your API keys!)
.env
.env.local
.env.*.local

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# ---- Node.js / Frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vite build output
frontend/dist/
frontend/.vite/

# TypeScript build info
*.tsbuildinfo

# ---- OS & Editor Files ----
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml

# ---- Misc ----
*.bak
*.tmp
*.swp
.coverage
htmlcov/
.pytest_cache/
