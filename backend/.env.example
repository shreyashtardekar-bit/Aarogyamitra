# VitalFlow Backend Environment Configuration
# Copy this file to .env and update with your actual API keys

# AI Services
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Nutrition API
SPOONACULAR_API_KEY=your-spoonacular-api-key-here

# Database Configuration
DATABASE_URL=sqlite:///./arogyamitra.db

# Security
SECRET_KEY=arogyamitra-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Application Settings
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# External Services
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
STRIPE_API_KEY=your-stripe-api-key-here
TWILIO_ACCOUNT_SID=your-twilio-sid-here
TWILIO_AUTH_TOKEN=your-twilio-token-here

# File Storage
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_BUCKET_NAME=arogyamitra-uploads
AWS_REGION=us-east-1

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
LOG_LEVEL=INFO
